# Image légère pour exécuter les migrations Drizzle
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

COPY lib/db ./lib/db
COPY drizzle.config.ts ./
# Les migrations générées par drizzle-kit
COPY drizzle ./drizzle

RUN npm install tsx --no-save

CMD ["npx", "tsx", "lib/db/migrate.ts"]
