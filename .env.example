# ==============================================================
# KamContent — Variables d'environnement (complet)
# Copier ce fichier en .env (Dokploy) ou .env.local (dev local)
# ==============================================================

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────

# URL publique de l'application (sans trailing slash)
# En prod : https://ton-domaine.com
# En dev  : http://localhost:3000
NEXT_PUBLIC_APP_URL=https://kamcontent.ton-domaine.com

# Port exposé par le conteneur app (défaut: 3000)
APP_PORT=3000


# ──────────────────────────────────────────────
# AUTHENTIFICATION — Clerk
# ──────────────────────────────────────────────
# Créer un compte sur https://clerk.com (gratuit : 50k users/mois)
# Tableau de bord → Create Application → Next.js
#
# Clerk Dashboard → API Keys

# Clé publique (préfixe pk_test_ ou pk_live_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Clé secrète (préfixe sk_test_ ou sk_live_) — NE JAMAIS EXPOSER
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Secret webhook (optionnel — pour sync Clerk → DB via webhooks)
# Clerk Dashboard → Webhooks → Add Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# URLs de redirection Clerk (configurer aussi dans le dashboard Clerk)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# ──────────────────────────────────────────────
# BASE DE DONNÉES — PostgreSQL
# ──────────────────────────────────────────────
# En Docker Compose, la DB est le service "db" — ne pas changer l'host

POSTGRES_DB=kamcontent
POSTGRES_USER=kamcontent
# Mot de passe fort recommandé en production
POSTGRES_PASSWORD=your_strong_password_here

# Construit automatiquement dans docker-compose.yml à partir des vars ci-dessus
# Pour dev local (sans Docker) : mettre l'URL complète ici
# DATABASE_URL=postgresql://kamcontent:password@localhost:5432/kamcontent


# ──────────────────────────────────────────────
# FOURNISSEUR IA — Choisir UN fournisseur
# ──────────────────────────────────────────────

# ┌─────────────────────────────────────────────┐
# │  OPTION 1 : Anthropic Claude (recommandé)   │
# │  https://console.anthropic.com              │
# └─────────────────────────────────────────────┘
AI_PROVIDER=anthropic
# Modèles disponibles : claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
AI_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 2 : OpenAI                          │
# │  https://platform.openai.com                │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini   # ou gpt-4o, gpt-4-turbo
# OPENAI_API_KEY=your_openai_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 3 : Google Gemini                   │
# │  https://aistudio.google.com                │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=google
# AI_MODEL=gemini-2.0-flash   # ou gemini-1.5-pro
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 4 : Mistral AI                      │
# │  https://console.mistral.ai                 │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=mistral
# AI_MODEL=mistral-small-latest   # ou mistral-large-latest
# MISTRAL_API_KEY=your_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 5 : DeepSeek                        │
# │  https://platform.deepseek.com              │
# │  Très bon rapport qualité/prix              │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat       # V3 — usage général
# AI_MODEL=deepseek-reasoner   # R1 — raisonnement avancé
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# (ou AI_API_KEY=sk-...)

# ┌─────────────────────────────────────────────┐
# │  OPTION 6 : Ollama (local, dans Docker)     │

# │  Ajouter le service ollama dans docker-     │
# │  compose.yml ou pointer vers un serveur ext │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2   # ou gemma3, mistral, phi4, etc.
# AI_BASE_URL=http://ollama:11434/v1   # service Docker
# AI_API_KEY=ollama   # Ollama ne vérifie pas la clé

# ┌─────────────────────────────────────────────┐
# │  OPTION 7 : OpenRouter (300+ modèles)       │
# │  https://openrouter.ai — gratuit jusqu'à    │
# │  10$/mois de crédits offerts                │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=openrouter
# AI_MODEL=anthropic/claude-sonnet-4-20250514
# AI_API_KEY=your_openrouter_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 8 : Groq (ultra-rapide, gratuit)    │
# │  https://console.groq.com                   │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=custom
# AI_MODEL=llama-3.3-70b-versatile   # ou mixtral-8x7b
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_groq_api_key_here

# ┌─────────────────────────────────────────────┐
# │  OPTION 9 : Together AI                     │
# │  https://api.together.xyz                   │
# └─────────────────────────────────────────────┘
# AI_PROVIDER=custom
# AI_MODEL=meta-llama/Llama-3-70b-chat-hf
# AI_BASE_URL=https://api.together.xyz/v1
# AI_API_KEY=your_api_key_here


# ──────────────────────────────────────────────
# RECHERCHE WEB — SearXNG (auto-hébergé)
# ──────────────────────────────────────────────
# En Docker Compose, SearXNG est le service "searxng"
# L'URL est définie automatiquement dans docker-compose.yml
# SEARXNG_URL=http://searxng:8080   (valeur par défaut dans le code)

# Clé secrète SearXNG (générer avec : openssl rand -hex 32)
SEARXNG_SECRET_KEY=your_searxng_secret_key_here


# ──────────────────────────────────────────────
# NOTIFICATIONS — Telegram Bot
# ──────────────────────────────────────────────
# 1. Créer un bot : parler à @BotFather sur Telegram
# 2. /newbot → suivre les instructions → copier le token
# 3. Obtenir son Chat ID : parler à @userinfobot

# Token du bot (format : 1234567890:ABCdefGHI...)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID par défaut (peut aussi être configuré par utilisateur dans Settings)
TELEGRAM_CHAT_ID=your_chat_id_here


# ──────────────────────────────────────────────
# WHATSAPP — Evolution API (auto-hébergé)
# ──────────────────────────────────────────────
# Evolution API tourne comme service Docker dans le même stack
# Documentation : https://doc.evolution-api.com
#
# URL interne (utilisée par l'app Next.js pour appeler l'API)
# Ne pas changer si tu utilises docker-compose (nom du service = "evolution")
EVOLUTION_API_URL=http://evolution:8080

# Clé API globale d'Evolution (doit correspondre à AUTHENTICATION_API_KEY dans le service)
# Générer avec : openssl rand -hex 32
EVOLUTION_API_KEY=your_evolution_api_key_here

# Port exposé par le service Evolution en local (pour admin ou debug)
# En production, tu peux désactiver l'exposition externe
EVOLUTION_PORT=8081

# URL publique du serveur Evolution (pour les webhooks, si besoin)
# En prod : https://evolution.ton-domaine.com
# En dev  : http://localhost:8081
EVOLUTION_SERVER_URL=http://localhost:8081

# Base de données Evolution (schéma séparé dans le même PostgreSQL)
EVOLUTION_DB=evolution


# ──────────────────────────────────────────────
# SÉCURITÉ
# ──────────────────────────────────────────────
# Secret pour protéger le cron job /api/telegram-notify
# Générer avec : openssl rand -hex 32
CRON_SECRET=your_cron_secret_here


# ──────────────────────────────────────────────
# NOTES DOKPLOY
# ──────────────────────────────────────────────
# 1. Dans Dokploy → ton projet → Environnement :
#    Coller toutes les variables ci-dessus (avec les vraies valeurs)
#
# 2. Dokploy injecte automatiquement ces variables via docker-compose.yml
#    grâce au mécanisme ${VAR_NAME} dans le fichier compose
#
# 3. Variables de build (NEXT_PUBLIC_*) :
#    Elles doivent être disponibles au BUILD TIME, pas seulement au runtime.
#    Dans Dokploy → Build Args, ajouter :
#      NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
#      NEXT_PUBLIC_APP_URL=https://ton-domaine.com
#
# 4. Domaine custom :
#    Dokploy → ton service → Domains → Add Domain
#    Pointer ton DNS vers l'IP Dokploy (A record)
#
# 5. Pour les migrations :
#    Le service "migrate" tourne une seule fois au démarrage
#    et applique les migrations Drizzle automatiquement
